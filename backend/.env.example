# ─── BASE DE DATOS ───────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=agroservicio
DB_USER=postgres
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA_AHORA

# ─── JWT ─────────────────────────────────────────────────────────────────────
# IMPORTANTE: Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mínimo 32 caracteres, máximo seguridad con 64+
JWT_SECRET=GENERA_UN_SECRETO_LARGO_Y_ALEATORIO_AQUI_MINIMO_64_CARACTERES
JWT_EXPIRES=8h

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ────────────────────────────────────────────────────────────────────
# URLs permitidas separadas por coma (sin espacios al final)
# Ejemplos: http://localhost:8080,https://tudominio.com
ALLOWED_ORIGINS=http://localhost:8080
